generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

model Course {
  id                     String           @id @default(uuid())
  slug                   String           @unique
  name                   String
  address                String?
  city                   String?
  state                  String?
  zip                    String?
  phone                  String?
  website                String?
  email                  String?
  logoUrl                String?
  heroImageUrl           String?
  primaryColor           String?          @default("#0D3522")
  secondaryColor         String?          @default("#C9A84C")
  latitude               Float?
  longitude              Float?
  timezone               String           @default("America/Chicago")
  stripeAccountId        String?
  stripeOnboarded        Boolean          @default(false)
  status                 CourseStatus     @default(pending)
  linxtimesFee           Int              @default(100)
  notificationEmail      String?
  payAtCourseEnabled     Boolean          @default(false)
  maxDaysAhead           Int              @default(14)
  bookingIntervalMin     Int              @default(10)
  onboardedAt            DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  linxtimesInPersonFee   Int              @default(50)
  stripeTerminalReaderId String?
  taxRateBps             Int              @default(0)
  announcement           String?
  cancellationFeeBps     Int              @default(0)
  bookings               Booking[]
  adminUsers             CourseAdmin[]
  dailyOverrides         DailyOverride[]
  layouts                Layout[]
  members                Member[]
  membershipTiers        MembershipTier[]
  promoCodes             PromoCode[]
  rainChecks             RainCheck[]
  shopItems              ShopItem[]
  waitlist               Waitlist[]

  @@map("courses")
}

model CourseAdmin {
  id           String     @id @default(uuid())
  courseId     String
  email        String     @unique
  passwordHash String
  name         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  role         CourseRole @default(owner)
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_admins")
}

model Layout {
  id           String        @id @default(uuid())
  courseId     String
  name         String
  holes        Int           @default(18)
  isActive     Boolean       @default(true)
  bookings     Booking[]
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  pricing      Pricing?
  teeTimeSlots TeeTimeSlot[]
  waitlist     Waitlist[]

  @@map("layouts")
}

model TeeTimeSlot {
  id          String  @id @default(uuid())
  layoutId    String
  dayOfWeek   Int
  startTime   String
  endTime     String
  intervalMin Int     @default(10)
  maxPlayers  Int     @default(4)
  isActive    Boolean @default(true)
  layout      Layout  @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@unique([layoutId, dayOfWeek])
  @@map("tee_time_slots")
}

model DailyOverride {
  id           String   @id @default(uuid())
  courseId     String
  overrideDate DateTime @db.Date
  slotTime     String?
  isClosed     Boolean  @default(true)
  maxPlayers   Int?
  reason       String?
  createdAt    DateTime @default(now())
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("daily_overrides")
}

model PromoCode {
  id             String       @id @default(uuid())
  courseId       String
  code           String
  kind           DiscountKind
  value          Int
  isActive       Boolean      @default(true)
  expiresAt      DateTime?
  maxRedemptions Int?
  timesRedeemed  Int          @default(0)
  createdAt      DateTime     @default(now())
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, code])
  @@map("promo_codes")
}

model ShopItem {
  id         String   @id @default(uuid())
  courseId   String
  name       String
  priceCents Int
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("shop_items")
}

model RainCheck {
  id                String    @id @default(uuid())
  courseId          String
  code              String
  amountCents       Int
  reason            String?
  note              String?
  originBookingId   String?
  isActive          Boolean   @default(true)
  redeemedAt        DateTime?
  redeemedBookingId String?
  createdBy         String?
  createdAt         DateTime  @default(now())
  course            Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, code])
  @@map("rain_checks")
}

model Waitlist {
  id          String    @id @default(uuid())
  courseId    String
  layoutId    String
  bookingDate DateTime  @db.Date
  slotTime    String
  name        String
  email       String
  phone       String?
  numPlayers  Int       @default(1)
  notifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  layout      Layout    @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([courseId, layoutId, bookingDate, slotTime])
  @@map("waitlist")
}

model Pricing {
  id               String  @id @default(uuid())
  layoutId         String  @unique
  weekdayFee       Int     @default(5000)
  weekendFee       Int     @default(7000)
  twilightFee      Int     @default(3000)
  twilightHour     Int     @default(16)
  memberFee        Int     @default(2500)
  cartFee          Int     @default(1500)
  cartAvailable    Boolean @default(true)
  nineHoleDiscount Boolean @default(true)
  layout           Layout  @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@map("pricing")
}

model MembershipTier {
  id         String   @id @default(uuid())
  courseId   String
  name       String
  priceCents Int
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  members    Member[]
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, name])
  @@map("membership_tiers")
}

model Member {
  id               String          @id @default(uuid())
  courseId         String
  memberId         String
  firstName        String
  lastName         String
  email            String?
  phone            String?
  membershipType   MembershipType  @default(full)
  greenFeeOverride Int?
  cartIncluded     Boolean         @default(false)
  discountDays     DiscountDays    @default(all)
  isActive         Boolean         @default(true)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  membershipTierId String?
  membershipPaidAt DateTime?
  bookings         Booking[]
  course           Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  membershipTier   MembershipTier? @relation(fields: [membershipTierId], references: [id])

  @@unique([courseId, memberId])
  @@map("members")
}

model Booking {
  id                    String        @id @default(uuid())
  confirmationNo        String        @unique
  courseId              String
  layoutId              String
  memberId              String?
  bookingDate           DateTime      @db.Date
  slotTime              String
  numPlayers            Int
  withCart              Boolean       @default(false)
  holes                 Int           @default(18)
  golferName            String
  golferEmail           String
  golferPhone           String?
  rateType              RateType      @default(weekday)
  greenFeeCents         Int
  cartFeeCents          Int           @default(0)
  bookingFeeCents       Int
  totalCents            Int
  paymentStatus         PaymentStatus @default(unpaid)
  stripePaymentIntentId String?
  stripeTransferId      String?
  stripeChargeId        String?
  status                BookingStatus @default(confirmed)
  source                BookingSource @default(online)
  cancelledAt           DateTime?
  cancelledBy           String?
  cancellationReason    String?
  cancellationOverride  Boolean       @default(false)
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  amountPaidCents       Int           @default(0)
  memberCount           Int           @default(0)
  taxCents              Int           @default(0)
  termsAcceptedAt       DateTime?
  discountCents         Int           @default(0)
  promoCode             String?
  creditCents           Int           @default(0)
  rainCheckCode         String?
  inPersonFeesCents     Int           @default(0)
  slotHeldUntil         DateTime?
  course                Course        @relation(fields: [courseId], references: [id])
  layout                Layout        @relation(fields: [layoutId], references: [id])
  member                Member?       @relation(fields: [memberId], references: [id])
  payments              Payment[]

  @@index([layoutId, bookingDate, slotTime])
  @@index([courseId, bookingDate])
  @@index([golferEmail])
  @@index([confirmationNo])
  @@map("bookings")
}

model Payment {
  id                    String        @id @default(uuid())
  bookingId             String?
  courseId              String
  amountCents           Int
  feeCents              Int
  playersCovered        Int           @default(0)
  method                PaymentMethod @default(terminal)
  state                 PaymentState  @default(pending)
  stripePaymentIntentId String?
  createdBy             String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  addonSummary          String?
  addonsCents           Int           @default(0)
  taxCents              Int           @default(0)
  description           String?
  metadata              Json?
  booking               Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([courseId])
  @@map("payments")
}

model OnboardingRequest {
  id              String       @id @default(uuid())
  courseId        String?
  ownerName       String
  courseName      String
  city            String?
  state           String?
  estimatedRounds Int?
  phone           String?
  email           String
  message         String?
  status          CourseStatus @default(pending)
  reviewedAt      DateTime?
  reviewedBy      String?
  declineReason   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("onboarding_requests")
}

model OnboardingToken {
  id        String    @id @default(uuid())
  courseId  String
  token     String    @unique @default(uuid())
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("onboarding_tokens")
}

enum CourseStatus {
  pending
  approved
  active
  suspended
}

enum BookingStatus {
  confirmed
  checked_in
  cancelled
  no_show
}

enum PaymentStatus {
  unpaid
  paid_online
  pay_at_course
  refunded
  partially_paid
  paid_in_person
}

enum BookingSource {
  online
  walkin
  phone
}

enum PaymentMethod {
  terminal
  cash
  other
}

enum PaymentState {
  pending
  succeeded
  failed
  refunded
}

enum RateType {
  weekday
  weekend
  twilight
  member
}

enum DiscountDays {
  all
  mon_thu
}

enum MembershipType {
  full
  associate
  junior
  senior
  social
}

enum CourseRole {
  owner
  manager
  staff
}

enum DiscountKind {
  percent
  amount
}
